---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page Not Found"
  description="The page you requested does not exist."
  robots="noindex, nofollow"
>
  <section class="mt-16 mb-24 max-w-2xl">
    <p class="text-xs uppercase tracking-[0.24em] text-zinc-500 dark:text-zinc-400">
      Error 404
    </p>
    <h1 class="mt-3 text-4xl md:text-5xl font-semibold tracking-tight">
      This page does not exist.
    </h1>
    <p class="mt-4 text-base md:text-lg text-zinc-600 dark:text-zinc-300">
      The URL may be outdated, misspelled, or removed.
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/"
        class="inline-flex items-center rounded-md border border-zinc-200 px-4 py-2 text-sm font-medium hover:bg-orange-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
      >
        Go Home
      </a>
      <a
        href="/blog"
        class="inline-flex items-center rounded-md border border-zinc-200 px-4 py-2 text-sm font-medium hover:bg-orange-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
      >
        Read Blog
      </a>
      <a
        href="/about"
        class="inline-flex items-center rounded-md border border-zinc-200 px-4 py-2 text-sm font-medium hover:bg-orange-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
      >
        About
      </a>
    </div>
  </section>
</Layout>
